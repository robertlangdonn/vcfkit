---
// Custom hero for vcfkit.dev landing page.
// Replaces Starlight's built-in Hero on splash pages.
---

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-wordmark">
      <span class="vk-bracket">[</span>vcfkit<span class="vk-bracket">]</span>
    </h1>

    <span class="acgt-stripe" aria-hidden="true"></span>

    <p class="hero-tagline">
      Fast VCF operations. Validated against bcftools. Ask in plain English.
    </p>

    <div class="hero-stats">
      <span>4× faster than bcftools</span>
      <span class="hero-stats-sep">·</span>
      <span>Validated on 1.1M variants</span>
      <span class="hero-stats-sep">·</span>
      <span>Open source</span>
    </div>

    <div class="hero-cta">
      <a href="#demo" class="btn-primary">Try the demo</a>
      <button
        class="btn-secondary"
        id="install-copy-btn"
        title="Copy install command"
        aria-label="Copy: cargo install vcfkit-cli"
      >cargo install vcfkit-cli</button>
      <a
        href="https://github.com/robertlangdonn/vcfkit"
        class="btn-ghost"
        target="_blank"
        rel="noopener noreferrer"
      >View on GitHub →</a>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('install-copy-btn');
  if (btn) {
    const original = btn.textContent ?? '';
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText('cargo install vcfkit-cli').then(() => {
        btn.textContent = 'Copied ✓';
        setTimeout(() => { btn.textContent = original; }, 2000);
      });
    });
  }
</script>
