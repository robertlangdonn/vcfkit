---
// vcfkit.dev landing page — native Astro, completely custom layout.
// Starlight handles /install, /commands/*, /benchmarks, /privacy, /credits.
import Demo from '../components/Demo.tsx';
import BenchmarkTable from '../components/BenchmarkTable.astro';
import '../styles/custom.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>vcfkit — Fast VCF operations</title>
  <meta name="description" content="Fast VCF operations — normalize, liftover, filter — validated against bcftools. Open source, single binary, no htslib. Ask in plain English." />
  <link rel="icon" href="/favicon.svg" />
  <meta property="og:title" content="vcfkit" />
  <meta property="og:description" content="Fast VCF operations validated against bcftools. Single binary, no htslib. Ask in plain English." />
  <meta property="og:image" content="https://vcfkit.dev/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
</head>

<body>

{/* Theme detection — runs before paint, reads Starlight's stored preference */}
<script is:inline>
  (function () {
    var stored = localStorage.getItem('starlight-theme');
    var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.dataset.theme = theme;
  })();
</script>

{/* ── Nav ───────────────────────────────────────────────────────────────── */}
<nav class="l-nav">
  <div class="l-nav-inner">
    <a href="/" class="l-nav-logo" aria-label="vcfkit — home">
      <span class="l-bracket">[</span>vcfkit<span class="l-bracket">]</span>
    </a>
    <div class="l-nav-links">
      <a href="/install" class="l-nav-link">Docs</a>
      <a href="https://github.com/robertlangdonn/vcfkit" class="l-nav-link" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://crates.io/crates/vcfkit-cli" class="l-nav-link l-nav-link--mono" target="_blank" rel="noopener noreferrer">crates.io</a>
    </div>
  </div>
</nav>

<main>

  {/* ── Hero ──────────────────────────────────────────────────────────────── */}
  <section class="l-hero">
    <div class="l-hero-inner">
      <h1 class="l-hero-name">
        <span class="l-bracket">[</span>vcfkit<span class="l-bracket">]</span>
      </h1>
      <span class="acgt-stripe" aria-hidden="true"></span>
      <p class="l-hero-tagline">
        Fast VCF operations. Validated against bcftools.<br />Ask in plain English.
      </p>

      <div class="l-stats">
        <div class="l-stat">
          <span class="l-stat-num">4×</span>
          <span class="l-stat-label">faster than bcftools</span>
        </div>
        <div class="l-stat-sep"></div>
        <div class="l-stat">
          <span class="l-stat-num">1.1M</span>
          <span class="l-stat-label">variants validated</span>
        </div>
        <div class="l-stat-sep"></div>
        <div class="l-stat">
          <span class="l-stat-num">100+</span>
          <span class="l-stat-label">test cases</span>
        </div>
        <div class="l-stat-sep"></div>
        <div class="l-stat">
          <span class="l-stat-num">0</span>
          <span class="l-stat-label">C dependencies</span>
        </div>
      </div>

      <div class="l-hero-cta">
        <a href="#demo" class="l-btn l-btn-primary">Try the demo</a>
        <button id="install-btn" class="l-btn l-btn-code" title="Click to copy">cargo install vcfkit-cli</button>
        <a href="https://github.com/robertlangdonn/vcfkit" class="l-btn l-btn-ghost" target="_blank" rel="noopener noreferrer">View on GitHub →</a>
      </div>
    </div>
  </section>

  {/* ── Demo ──────────────────────────────────────────────────────────────── */}
  <section id="demo" class="l-demo">
    <div class="l-container">
      <div class="l-demo-header">
        <h2 class="l-demo-title">Try it in your browser</h2>
        <span class="l-privacy-note">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Your VCF never leaves this tab
        </span>
      </div>
      <Demo client:only="react" />
    </div>
  </section>

  {/* ── What is this ──────────────────────────────────────────────────────── */}
  <section class="l-what l-section">
    <div class="l-container l-narrow">
      <p class="l-kicker">What it is</p>
      <h2 class="l-section-h2">
        Three operations every VCF pipeline needs,<br />rewritten for speed and correctness.
      </h2>
      <div class="l-what-body">
        <p>
          vcfkit is a fast, open-source CLI for normalize, liftover, and filter — in one binary,
          with no htslib dependency. Validated against bcftools on real 1000 Genomes data.
        </p>
        <p>
          It doesn't replace bcftools. It does three operations well, with modern UX, and adds
          an optional AI-powered natural-language layer for filter queries.
        </p>
        <p>
          The same core runs in your browser via WebAssembly — paste a VCF in the demo above
          and nothing uploads.
        </p>
      </div>
    </div>
  </section>

  {/* ── Three operations ──────────────────────────────────────────────────── */}
  <section class="l-ops l-section">
    <div class="l-container">
      <div class="l-ops-grid">

        <div class="l-ops-card">
          <div class="l-ops-name">normalize</div>
          <p class="l-ops-desc">
            Left-align indels, split multi-allelic sites, validate against a reference genome.
            Handles <code>Number=A</code>, <code>Number=R</code>, and <code>Number=G</code> fields correctly.
          </p>
          <pre class="l-ops-cmd">vcfkit normalize \
  -f ref.fa input.vcf</pre>
          <a class="l-ops-link" href="/commands/normalize">Docs →</a>
        </div>

        <div class="l-ops-card">
          <div class="l-ops-name">liftover</div>
          <p class="l-ops-desc">
            Convert variants between genome builds using UCSC chain files.
            Detects b37/UCSC contig mismatches. Unmapped records go to a reject file.
          </p>
          <pre class="l-ops-cmd">vcfkit liftover \
  -s hg19.fa -t hg38.fa \
  -c chain.gz input.vcf</pre>
          <a class="l-ops-link" href="/commands/liftover">Docs →</a>
        </div>

        <div class="l-ops-card">
          <div class="l-ops-name">filter</div>
          <p class="l-ops-desc">
            Keep variants matching a deterministic expression.
            Supports INFO, FORMAT, CHROM, POS, QUAL, FILTER, regex, and multi-allelic any-element semantics.
          </p>
          <pre class="l-ops-cmd">vcfkit filter \
  -e "INFO/AF &lt; 0.01 &amp;&amp; FILTER == 'PASS'" \
  input.vcf</pre>
          <a class="l-ops-link" href="/commands/filter">Docs →</a>
        </div>

      </div>
    </div>
  </section>

  {/* ── --ask section ─────────────────────────────────────────────────────── */}
  <section class="l-ask l-section">
    <div class="l-container">
      <div class="l-ask-layout">

        <div class="l-ask-prose">
          <p class="l-kicker">Natural-language filter</p>
          <h2 class="l-section-h2">Ask in plain English.</h2>
          <p class="l-ask-p">
            Describe the filter you want. An AI translates it to a deterministic
            expression, shows you what it will run, and asks before running.
          </p>
          <ul class="l-callouts">
            <li>
              <span class="l-callout-marker">→</span>
              <span><strong>Header schema only.</strong> Field names, types, and descriptions go to the AI. Variant data never leaves your machine.</span>
            </li>
            <li>
              <span class="l-callout-marker">→</span>
              <span><strong>Gate at 50%.</strong> Low-confidence translations require explicit review before running — no silent wrong results.</span>
            </li>
            <li>
              <span class="l-callout-marker">→</span>
              <span><strong>Open source.</strong> Read exactly what gets sent in <a href="https://github.com/robertlangdonn/vcfkit/blob/main/crates/vcfkit-cli/src/ask.rs" target="_blank" rel="noopener noreferrer">ask.rs</a>.</span>
            </li>
          </ul>
          <div style="margin-top: 1.75rem;">
            <a href="/commands/filter#natural-language-filter---ask" class="l-btn l-btn-code l-btn-sm">
              Set up ANTHROPIC_API_KEY →
            </a>
          </div>
        </div>

        <div class="l-ask-terminal-wrap">
          <div class="l-terminal">
            <div class="l-terminal-bar">
              <span class="l-dot l-dot-red"></span>
              <span class="l-dot l-dot-yellow"></span>
              <span class="l-dot l-dot-green"></span>
              <span class="l-terminal-label">vcfkit</span>
            </div>
            <pre class="l-terminal-body"><span class="t-dim">$</span> <span class="t-bright">vcfkit filter --ask \</span>
<span class="t-bright">    "common variants in EUR but rare in AFR" \</span>
<span class="t-bright">    input.vcf</span>

<span class="t-dim">  Query:     </span><span class="t-bright"> common variants in EUR but rare in AFR</span>
<span class="t-dim">  Expression:</span><span class="t-accent"> INFO/EUR_AF &gt; 0.05 &amp;&amp; INFO/AFR_AF &lt; 0.01</span>
<span class="t-dim">  Confidence:</span><span class="t-accent"> 95%</span>

<span class="t-bright">Run this filter? [Y/n/edit] </span><span class="t-cursor">▋</span></pre>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ── Benchmarks ────────────────────────────────────────────────────────── */}
  <section class="l-bench l-section">
    <div class="l-container">
      <div class="l-bench-hero">
        <span class="l-bench-num">4×</span>
        <p class="l-bench-label">faster than bcftools on 1.1M variants</p>
      </div>
      <BenchmarkTable />
      <div class="l-bench-links">
        <a href="https://github.com/robertlangdonn/vcfkit/blob/main/BENCHMARKS.md" target="_blank" rel="noopener noreferrer">
          Methodology and reproduction steps →
        </a>
        <a href="https://github.com/robertlangdonn/vcfkit/actions/workflows/nightly-real-tests.yml" target="_blank" rel="noopener noreferrer">
          Nightly differential tests vs bcftools →
        </a>
      </div>
    </div>
  </section>

  {/* ── Credits + Trust + Contact ─────────────────────────────────────────── */}
  <section class="l-bottom l-section">
    <div class="l-container">
      <div class="l-bottom-grid">

        <div>
          <p class="l-group-label">Credits</p>
          <p class="l-group-sub">vcfkit exists because of decades of work by others.</p>
          <div class="l-credits-grid">

            <div class="l-credit">
              <div class="l-credit-name">htslib and bcftools</div>
              <p class="l-credit-body">
                Reference implementations for VCF/BCF processing.
                <a href="https://www.sanger.ac.uk/" target="_blank" rel="noopener noreferrer">Wellcome Sanger Institute</a>.
                Primary authorship: Heng Li, Petr Danecek, and hundreds of contributors over 15+ years.
                If vcfkit and bcftools diverge, vcfkit is wrong by default.
              </p>
            </div>

            <div class="l-credit">
              <div class="l-credit-name">noodles</div>
              <p class="l-credit-body">
                Pure-Rust I/O for VCF, BCF, FASTA, and chain files, by
                <a href="https://github.com/zaeleus" target="_blank" rel="noopener noreferrer">Michael Macias</a>.
                Without noodles this project wouldn't exist.
              </p>
            </div>

            <div class="l-credit">
              <div class="l-credit-name">Tan, Abecasis, Kang 2015</div>
              <p class="l-credit-body">
                "Unified representation of genetic variants."
                <a href="https://doi.org/10.1093/bioinformatics/btv112" target="_blank" rel="noopener noreferrer"><em>Bioinformatics</em> 31(13):2202–2204</a>.
                The normalization algorithm in <code>vcfkit normalize</code>.
              </p>
            </div>

            <div class="l-credit">
              <div class="l-credit-name">UCSC Genome Browser</div>
              <p class="l-credit-body">
                Chain files and reference FASTAs used by <code>vcfkit liftover</code>.
                <a href="https://hgdownload.soe.ucsc.edu/goldenPath/" target="_blank" rel="noopener noreferrer">Download chain files →</a>
              </p>
            </div>

          </div>
        </div>

        <div class="l-right-col">

          <div>
            <p class="l-group-label">Trust and limitations</p>
            <div class="l-trust">
              <ul>
                <li><strong>Correctness</strong> — validated against bcftools on 1000 Genomes data. Differential tests run nightly in CI.</li>
                <li><strong>Open source</strong> — code is auditable and forkable. <a href="https://github.com/robertlangdonn/vcfkit" target="_blank" rel="noopener noreferrer">GitHub →</a></li>
                <li><strong>Status</strong> — v0.3.0. Suitable for research pipelines and evaluation.</li>
                <li><strong>Not validated for clinical use.</strong> Known differences from bcftools are <a href="/known-differences">documented</a>.</li>
              </ul>
            </div>
          </div>

          <div>
            <p class="l-group-label">Get in touch</p>
            <ul class="l-contact">
              <li>Bug reports: <a href="https://github.com/robertlangdonn/vcfkit/issues" target="_blank" rel="noopener noreferrer">GitHub Issues</a></li>
              <li>Questions: <a href="https://github.com/robertlangdonn/vcfkit/discussions" target="_blank" rel="noopener noreferrer">GitHub Discussions</a></li>
              <li>Email: <a href="mailto:prasadkhake@gmail.com">prasadkhake@gmail.com</a></li>
            </ul>
            <p class="l-invite">If you're using vcfkit in research or production, I'd love to hear about it.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

</main>

{/* ── Footer ────────────────────────────────────────────────────────────── */}
<footer class="l-footer">
  <div class="l-footer-inner">
    <span>Built by <a href="https://prasadkhake.com" target="_blank" rel="noopener noreferrer">Prasad Khake</a></span>
    <span class="l-footer-sep">·</span>
    <span>Open source</span>
    <span class="l-footer-sep">·</span>
    <a href="https://github.com/robertlangdonn/vcfkit" target="_blank" rel="noopener noreferrer">GitHub</a>
    <span class="l-footer-sep">·</span>
    <a href="https://crates.io/crates/vcfkit-cli" target="_blank" rel="noopener noreferrer">crates.io</a>
    <span class="l-footer-sep">·</span>
    <a href="/install">Docs</a>
    <span class="l-footer-sep">·</span>
    <span>&copy; 2026</span>
  </div>
</footer>

<script>
  // Install copy button
  const btn = document.getElementById('install-btn');
  if (btn) {
    const orig = btn.textContent ?? '';
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText('cargo install vcfkit-cli').then(() => {
        btn.textContent = 'Copied ✓';
        setTimeout(() => { btn.textContent = orig; }, 2000);
      });
    });
  }
</script>

</body>
</html>

<style is:global>

/* ─────────────────────────────────────────────────────────────────────────
   Landing page — Starlight variable mappings (for Demo component compat)
───────────────────────────────────────────────────────────────────────── */

:root,
:root[data-theme='dark'] {
  --sl-color-white:       #D6EFED;
  --sl-color-black:       #0a1f1e;
  --sl-color-text:        #D6EFED;
  --sl-color-text-accent: #56D4C8;
  --sl-color-green:       #4ADE80;
  --sl-color-orange:      #f97316;
  --sl-color-gray-1:      #b8d8d5;
  --sl-color-gray-2:      #8ab2ae;
  --sl-color-gray-3:      #6DA8A2;
  --sl-color-gray-4:      #4d7a76;
  --sl-color-gray-5:      #2a4a47;
  --sl-color-gray-6:      #1e3d3a;
  --sl-color-gray-7:      #122724;
}

:root[data-theme='light'] {
  --sl-color-white:       #0E2523;
  --sl-color-black:       #F2FAFA;
  --sl-color-text:        #0E2523;
  --sl-color-text-accent: #2E9688;
  --sl-color-green:       #16a34a;
  --sl-color-gray-1:      #1a4540;
  --sl-color-gray-2:      #2e6b64;
  --sl-color-gray-3:      #527874;
  --sl-color-gray-4:      #6a9a96;
  --sl-color-gray-5:      #BFD9D6;
  --sl-color-gray-6:      #d0e8e5;
  --sl-color-gray-7:      #E6F4F2;
}

/* ─────────────────────────────────────────────────────────────────────────
   Global reset
───────────────────────────────────────────────────────────────────────── */

*, *::before, *::after { box-sizing: border-box; }

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  background: var(--vk-bg, #0E1F1E);
  color: var(--sl-color-text);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
}

/* ─────────────────────────────────────────────────────────────────────────
   Terminal token colours (used in the --ask section)
───────────────────────────────────────────────────────────────────────── */

.t-dim    { color: #5a8a85; }
.t-bright { color: #c8e8e4; }
.t-accent { color: #56D4C8; font-weight: 600; }
.t-cursor { color: #56D4C8; animation: blink 1.1s step-end infinite; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

/* ─────────────────────────────────────────────────────────────────────────
   Layout utilities
───────────────────────────────────────────────────────────────────────── */

.l-container {
  max-width: 1100px;
  margin-inline: auto;
  padding-inline: max(1.5rem, 5vw);
}
.l-narrow {
  max-width: 620px;
  margin-inline: auto;
  padding-inline: max(1.5rem, 5vw);
}
.l-section {
  padding-block: 96px;
}
@media (max-width: 768px) {
  .l-section { padding-block: 64px; }
}

/* ─────────────────────────────────────────────────────────────────────────
   Nav
───────────────────────────────────────────────────────────────────────── */

.l-nav {
  position: fixed;
  inset-block-start: 0;
  inset-inline: 0;
  z-index: 100;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  background: color-mix(in srgb, var(--vk-bg) 82%, transparent);
  border-bottom: 1px solid color-mix(in srgb, var(--vk-border) 50%, transparent);
}
.l-nav-inner {
  max-width: 1100px;
  margin-inline: auto;
  padding-inline: max(1.5rem, 5vw);
  height: 54px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.l-nav-logo {
  font-family: var(--font-mono);
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-decoration: none;
  color: var(--sl-color-text);
}
.l-bracket { color: var(--vk-accent); font-weight: 400; }
.l-nav-links {
  display: flex;
  align-items: center;
  gap: 2px;
}
.l-nav-link {
  padding: 0.35rem 0.7rem;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--sl-color-text);
  text-decoration: none;
  border-radius: 6px;
  transition: background 0.15s;
  opacity: 0.7;
}
.l-nav-link:hover { background: color-mix(in srgb, var(--vk-accent) 8%, transparent); opacity: 1; }
.l-nav-link--mono { font-family: var(--font-mono); font-size: 0.78rem; }

/* ─────────────────────────────────────────────────────────────────────────
   Hero
───────────────────────────────────────────────────────────────────────── */

.l-hero {
  padding-top: calc(54px + 7rem);
  padding-bottom: 6rem;
  padding-inline: max(1.5rem, 5vw);
  text-align: center;
  background:
    radial-gradient(ellipse 110% 60% at 50% 0%, rgba(46, 150, 136, 0.14) 0%, transparent 65%),
    transparent;
}
.l-hero-inner {
  max-width: 640px;
  margin-inline: auto;
}
.l-hero-name {
  font-family: var(--font-mono);
  font-size: clamp(4rem, 11vw, 6.5rem);
  font-weight: 700;
  line-height: 1;
  margin: 0;
  letter-spacing: -0.02em;
  color: #edf9f8;
}
:root[data-theme='light'] .l-hero-name { color: var(--vk-text); }
.l-hero-tagline {
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  color: var(--vk-text-muted);
  line-height: 1.65;
  margin: 1.75rem auto 0;
  max-width: 480px;
}
/* acgt-stripe is defined in custom.css */

/* Stats */
.l-stats {
  display: flex;
  align-items: stretch;
  justify-content: center;
  margin: 2.5rem 0;
  flex-wrap: wrap;
  gap: 0;
}
.l-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 0 2rem;
  border-right: 1px solid var(--vk-border);
}
.l-stat:last-child { border-right: none; }
.l-stat-num {
  font-family: var(--font-mono);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--vk-accent);
  line-height: 1;
}
.l-stat-label {
  font-size: 0.68rem;
  color: var(--vk-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  white-space: nowrap;
}
@media (max-width: 560px) {
  .l-stats { gap: 0.75rem; flex-wrap: wrap; justify-content: center; }
  .l-stat  { border-right: none; padding: 0 1.25rem; }
}

/* CTAs */
.l-hero-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.65rem;
  flex-wrap: wrap;
}
.l-btn {
  display: inline-flex;
  align-items: center;
  padding: 0.6rem 1.35rem;
  border-radius: 7px;
  font-size: 0.88rem;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: opacity 0.15s, background 0.15s;
  font-family: var(--font-sans);
  line-height: 1;
}
.l-btn:hover { opacity: 0.85; }
.l-btn-primary {
  background: var(--vk-accent);
  color: #081f1e;
}
.l-btn-code {
  background: color-mix(in srgb, var(--vk-accent) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--vk-accent) 35%, transparent);
  color: var(--vk-accent);
  font-family: var(--font-mono);
  font-size: 0.8rem;
}
.l-btn-ghost {
  color: var(--vk-text-muted);
  background: transparent;
  border: 1px solid var(--vk-border);
}
.l-btn-ghost:hover { color: var(--sl-color-text); border-color: var(--vk-text-muted); }
.l-btn-sm { padding: 0.45rem 1rem; font-size: 0.82rem; }

/* ─────────────────────────────────────────────────────────────────────────
   Demo
───────────────────────────────────────────────────────────────────────── */

.l-demo {
  padding-block: 3.5rem;
  background: linear-gradient(
