---
import Demo from '../components/Demo.tsx';
import '../styles/custom.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>vcfkit — Fast VCF operations</title>
  <meta name="description" content="Fast VCF operations — normalize, liftover, filter — validated against bcftools. Single binary, no htslib, no dependencies." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta property="og:title" content="vcfkit" />
  <meta property="og:description" content="Fast VCF operations. Validated against bcftools. Single binary." />
  <meta property="og:image" content="https://vcfkit.dev/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
</head>

<body>

<script is:inline>
  (function () {
    var s = localStorage.getItem('starlight-theme');
    var t = s || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.dataset.theme = t;
  })();
</script>

<!-- ── Nav ─────────────────────────────────────────────────────────────── -->
<header class="g-nav">
  <div class="g-nav-inner">
    <a href="/" class="g-nav-logo" aria-label="vcfkit home">
      <span class="g-bracket">[</span>vcfkit<span class="g-bracket">]</span>
    </a>
    <nav class="g-nav-links" aria-label="Site navigation">
      <a href="/install" class="g-nav-link g-nav-icon-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Docs
      </a>
      <a href="https://github.com/robertlangdonn/vcfkit" target="_blank" rel="noopener noreferrer" class="g-nav-link g-nav-icon-link" aria-label="GitHub repository">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
      </a>
      <a href="https://crates.io/crates/vcfkit-cli" target="_blank" rel="noopener noreferrer" class="g-nav-link g-nav-icon-link g-nav-crates" aria-label="vcfkit on crates.io">
        <svg width="14" height="14" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
          <path d="M239.1 6.3l-208 78c-18.7 7-31.1 25-31.1 45v225.1c0 18.2 10.3 34.8 26.5 42.9l208 104c13.5 6.8 29.4 6.8 42.9 0l208-104c16.3-8.1 26.5-24.8 26.5-42.9V129.3c0-20-12.4-37.9-31.1-45l-208-78C262 2.2 250 2.2 239.1 6.3zM256 68.4l192 72v1.1l-192 78-192-78v-1.1l192-72zm32 356V275.5l160-65v133.9l-160 80z"/>
