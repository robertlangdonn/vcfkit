---
import Demo from '../components/Demo.tsx';
import '../styles/custom.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>vcfkit — Fast VCF operations</title>
  <meta name="description" content="Fast VCF operations — normalize, liftover, filter — validated against bcftools. Single binary, no htslib, no dependencies." />
  <link rel="icon" href="/favicon.svg" />
  <meta property="og:title" content="vcfkit" />
  <meta property="og:description" content="Fast VCF operations. Validated against bcftools. Single binary." />
  <meta property="og:image" content="https://vcfkit.dev/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
</head>

<body>

<script is:inline>
  (function () {
    var s = localStorage.getItem('starlight-theme');
    var t = s || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.dataset.theme = t;
  })();
</script>

<!-- ── Nav ─────────────────────────────────────────────────────────────── -->
<header class="g-nav">
  <a href="/" class="g-nav-logo" aria-label="vcfkit home">
    <span class="g-bracket">[</span>vcfkit<span class="g-bracket">]</span>
  </a>
  <nav class="g-nav-links" aria-label="Site navigation">
    <a href="/install">Docs</a>
    <a href="https://github.com/robertlangdonn/vcfkit" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="https://crates.io/crates/vcfkit-cli" target="_blank" rel="noopener noreferrer">crates.io</a>
  </nav>
</header>

<main>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="g-hero">
    <div class="g-inner">
      <h1 class="g-wordmark">
        <span class="g-bracket">[</span>vcfkit<span class="g-bracket">]</span>
      </h1>
      <p class="g-tagline">
        Fast VCF operations. Validated against bcftools. Single binary.
      </p>
      <p class="g-tagline-sub">
        Three operations every VCF pipeline needs — normalize, liftover, filter — measurably faster than bcftools, in one binary with no htslib.
      </p>
      <div class="g-install">
        <code class="g-install-cmd" id="install-cmd">brew install vcfkit</code>
        <button class="g-copy-btn" id="copy-btn" aria-label="Copy install command" onclick="
          navigator.clipboard.writeText('brew install vcfkit').then(function(){
            var b = document.getElementById('copy-btn');
            b.textContent = 'copied';
            b.classList.add('g-copy-btn--done');
            setTimeout(function(){ b.textContent = 'copy'; b.classList.remove('g-copy-btn--done'); }, 1800);
          });
        ">copy</button>
      </div>
      <p class="g-hero-sub">
        or <a href="/install">see all install options →</a>
      </p>
    </div>
  </section>

  <!-- ── Demo ──────────────────────────────────────────────────────────── -->
  <section class="g-demo-section">
    <div class="g-inner g-inner--wide">
      <Demo client:only="react" />
    </div>
  </section>

  <!-- ── What ──────────────────────────────────────────────────────────── -->
  <section class="g-section">
    <div class="g-inner g-inner--prose">
      <h2 class="g-section-h">What it is</h2>
      <p>
        vcfkit does three things every VCF pipeline needs — normalize, liftover, and filter —
        rewritten in Rust for speed and correctness. One static binary with no htslib dependency,
        measurably faster than bcftools on hot paths, and validated against it on real 1000 Genomes data.
      </p>
      <p>
        It doesn't replace bcftools. It does three operations well, with an optional natural-language
        filter that translates plain English to a deterministic expression.
        The same core runs in your browser via WebAssembly — nothing in the demo above uploads anywhere.
      </p>
    </div>
  </section>

  <!-- ── Operations ────────────────────────────────────────────────────── -->
  <section class="g-section">
    <div class="g-inner">
      <h2 class="g-section-h">Operations</h2>
      <dl class="g-ops">
        <div class="g-op">
          <dt><a href="/commands/normalize">normalize</a></dt>
          <dd>
            Left-align indels and split multi-allelic sites. Validates against a reference genome.
            A fast path handles biallelic SNPs/MNPs without full parsing (~80% of typical VCFs).
          </dd>
          <pre class="g-op-cmd"><code>vcfkit normalize -r ref.fa input.vcf</code></pre>
        </div>
        <div class="g-op">
          <dt><a href="/commands/liftover">liftover</a></dt>
          <dd>
            Convert between genome builds — hg19, hg38, T2T-CHM13 — using UCSC chain files.
            Handles strand flips and b37/UCSC contig name mismatches.
          </dd>
          <pre class="g-op-cmd"><code>vcfkit liftover --chain hg19ToHg38.chain.gz input.vcf</code></pre>
        </div>
        <div class="g-op">
          <dt><a href="/commands/filter">filter</a></dt>
          <dd>
            Select variants with expressions over INFO, FORMAT, CHROM, POS, QUAL, and FILTER fields.
            Or describe the filter in plain English with <code>--ask</code> and review the expression before it runs.
          </dd>
          <pre class="g-op-cmd"><code>vcfkit filter 'INFO/AF &lt; 0.01 &amp;&amp; FILTER == "PASS"' input.vcf</code></pre>
        </div>
      </dl>
    </div>
  </section>

  <!-- ── Benchmarks ────────────────────────────────────────────────────── -->
  <section class="g-section g-section--accent">
    <div class="g-inner g-inner--prose">
      <h2 class="g-section-h">Benchmarks</h2>
      <div class="g-bench-row">
        <div class="g-bench-stat">
          <span class="g-bench-num">4×</span>
          <span class="g-bench-label">faster than bcftools normalize<br/>(biallelic SNP/MNP fast path)</span>
        </div>
        <div class="g-bench-stat">
          <span class="g-bench-num">4×</span>
          <span class="g-bench-label">faster than bcftools filter<br/>(INFO/AF expression on 1.1M variants)</span>
        </div>
      </div>
      <p class="g-bench-note">
        Measured on 1000 Genomes chr22 · 1,103,547 variants · macOS aarch64 · bcftools 1.23.1.
        Liftover and multi-allelic normalize match bcftools within ±2%.
        <a href="https://github.com/robertlangdonn/vcfkit/blob/main/BENCHMARKS.md" target="_blank" rel="noopener noreferrer">Methodology →</a>
      </p>
    </div>
  </section>

  <!-- ── Ask ───────────────────────────────────────────────────────────── -->
  <section class="g-section">
    <div class="g-inner g-inner--prose">
      <h2 class="g-section-h">Ask in plain English</h2>
      <p>
        Describe the filter you want. vcfkit translates it to a deterministic expression using Claude,
        shows you what it will run, and asks before running. Your VCF data never leaves your machine —
        only the header schema goes to the API.
      </p>
      <pre class="g-pre"><code><span class="p-dim">$</span> vcfkit filter --ask \
    <span class="p-str">"common variants in Europeans but rare in Africans"</span> \
    input.vcf

<span class="p-label">Expression:</span> <span class="p-expr">INFO/EUR_AF &gt; 0.05 &amp;&amp; INFO/AFR_AF &lt; 0.01</span>
<span class="p-label">Confidence:</span> 95%

<span class="p-prompt">Run this filter? [Y/n/edit]</span></code></pre>
      <p class="g-note">
        Requires <code>ANTHROPIC_API_KEY</code>.
        Translations below 50% confidence require explicit review.
        <a href="/commands/filter#natural-language-filter---ask">Setup →</a>
      </p>
    </div>
  </section>

  <!-- ── Validation ────────────────────────────────────────────────────── -->
  <section class="g-section">
    <div class="g-inner g-inner--prose">
      <h2 class="g-section-h">Correctness</h2>
      <p>
        Every operation is validated against bcftools in differential tests on real 1000 Genomes chr22 data.
        Tests run nightly in CI. Known differences are documented.
      </p>
      <ul class="g-list">
        <li>100+ unit and integration tests</li>
        <li>Differential tests against bcftools on 1.1M real variants</li>
        <li>WASM parity tests — browser and CLI produce identical output</li>
        <li>Nightly CI against bcftools on 1000 Genomes data</li>
      </ul>
      <p>
        <a href="https://github.com/robertlangdonn/vcfkit/actions/workflows/nightly-real-tests.yml" target="_blank" rel="noopener noreferrer">Nightly differential tests →</a>
        &nbsp;&nbsp;
        <a href="/known-differences">Known differences →</a>
      </p>
      <p class="g-disclaimer">
        Not validated for clinical use. vcfkit is research and pipeline tooling only.
      </p>
    </div>
  </section>

  <!-- ── Install ───────────────────────────────────────────────────────── -->
  <section class="g-section">
    <div class="g-inner g-inner--prose">
      <h2 class="g-section-h">Install</h2>
      <pre class="g-pre"><code><span class="p-dim"># Homebrew</span>
brew install vcfkit

<span class="p-dim"># Cargo</span>
cargo install vcfkit-cli

<span class="p-dim"># Prebuilt binary (macOS, Linux, Windows)</span>
curl -fsSL https://vcfkit.dev/install.sh | sh</code></pre>
      <p><a href="/install">Full install instructions and shell completions →</a></p>
    </div>
  </section>

</main>

<!-- ── Footer ──────────────────────────────────────────────────────────── -->
<footer class="g-footer">
  <div class="g-inner">
    <span>
      Built by <a href="https://prasadkhake.com" target="_blank" rel="noopener noreferrer">Prasad Khake</a>
    </span>
    <span class="g-footer-sep">·</span>
    <span>
      <a href="https://github.com/robertlangdonn/vcfkit" target="_blank" rel="noopener noreferrer">Open source</a>
    </span>
    <span class="g-footer-sep">·</span>
    <span><a href="/privacy">Privacy</a></span>
    <span class="g-footer-sep">·</span>
    <span><a href="/credits">Credits</a></span>
    <span class="g-footer-sep">·</span>
    <span class="g-footer-copy">© 2026</span>
  </div>
</footer>

</body>
</html>

<style is:global>
/* ── Reset / base ────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --g-bg:        #0c0c0c;
  --g-bg-subtle: #111111;
  --g-border:    #1e1e1e;
  --g-text:      #d4d4d4;
  --g-text-dim:  #6b6b6b;
  --g-text-mute: #3d3d3d;
  --g-accent:    #2E9688;
  --g-accent-hi: #56D4C8;
  --g-bracket:   #56D4C8;
  --g-link:      #56D4C8;
  --g-code-bg:   #141414;

  /* Starlight compat — Demo.tsx uses these */
  --sl-color-gray-1: #e8e8e8;
  --sl-color-gray-2: #c0c0c0;
  --sl-color-gray-3: #888888;
  --sl-color-gray-4: #555555;
  --sl-color-gray-5: #2a2a2a;
  --sl-color-gray-6: #1a1a1a;
  --sl-color-gray-7: #111111;
  --sl-color-accent: var(--g-accent);
  --sl-color-accent-high: var(--g-accent-hi);
  --sl-color-bg:     var(--g-bg);
  --sl-color-bg-nav: var(--g-bg);
  --sl-color-text:   var(--g-text);
  --sl-font-mono: 'JetBrains Mono', ui-monospace, monospace;
  --sl-color-green: #4ade80;
  --sl-color-orange: #fb923c;

  --font-sans: 'Geist Variable', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', ui-monospace, monospace;
  --g-max: 920px;
  --g-max-wide: 1100px;
}

:root[data-theme='light'] {
  --g-bg:        #f8f8f6;
  --g-bg-subtle: #f0f0ee;
  --g-border:    #e2e2e0;
  --g-text:      #1a1a1a;
  --g-text-dim:  #6b6b6b;
  --g-text-mute: #c8c8c8;
  --g-accent:    #2E9688;
  --g-accent-hi: #1a7a70;
  --g-bracket:   #1a7a70;
  --g-link:      #1a7a70;
  --g-code-bg:   #efefed;

  --sl-color-gray-1: #111111;
  --sl-color-gray-2: #333333;
  --sl-color-gray-3: #555555;
  --sl-color-gray-4: #888888;
  --sl-color-gray-5: #cccccc;
  --sl-color-gray-6: #e0e0e0;
  --sl-color-gray-7: #f5f5f5;
  --sl-color-bg:     var(--g-bg);
  --sl-color-bg-nav: var(--g-bg);
  --sl-color-text:   var(--g-text);
}

html { background: var(--g-bg); color: var(--g-text); font-family: var(--font-sans); font-size: 16px; line-height: 1.6; }
body { background: var(--g-bg); }

a { color: var(--g-link); text-decoration: none; }
a:hover { text-decoration: underline; }

code {
  font-family: var(--font-mono);
  font-size: 0.875em;
  background: var(--g-code-bg);
  border: 1px solid var(--g-border);
  padding: 0.1em 0.35em;
  border-radius: 3px;
  color: var(--g-text);
}

/* ── Layout helpers ──────────────────────────────────────────────────── */
.g-inner {
  max-width: var(--g-max);
  margin: 0 auto;
  padding: 0 24px;
}
.g-inner--wide { max-width: var(--g-max-wide); }
.g-inner--prose { max-width: 680px; }

/* ── Nav ─────────────────────────────────────────────────────────────── */
.g-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  height: 52px;
  background: color-mix(in srgb, var(--g-bg) 85%, transparent);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--g-border);
}

.g-nav-logo {
  font-family: var(--font-mono);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--g-text);
  letter-spacing: -0.01em;
}
.g-nav-logo:hover { text-decoration: none; }

.g-bracket { color: var(--g-bracket); }

.g-nav-links {
  display: flex;
  gap: 28px;
  align-items: center;
  font-size: 0.875rem;
  color: var(--g-text-dim);
}
.g-nav-links a { color: var(--g-text-dim); }
.g-nav-links a:hover { color: var(--g-text); text-decoration: none; }

/* ── Hero ────────────────────────────────────────────────────────────── */
.g-hero {
  padding: 96px 0 72px;
  text-align: center;
}

.g-wordmark {
  font-family: var(--font-mono);
  font-size: clamp(3rem, 10vw, 5.5rem);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.03em;
  color: var(--g-text);
  margin-bottom: 20px;
}

.g-tagline {
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  color: var(--g-text-dim);
  margin-bottom: 16px;
  letter-spacing: -0.01em;
}

.g-tagline-sub {
  font-size: 0.9375rem;
  color: var(--g-text-dim);
  max-width: 520px;
  margin: 0 auto 32px;
  line-height: 1.6;
  opacity: 0.8;
}

.g-install {
  display: inline-flex;
  align-items: center;
  background: var(--g-code-bg);
  border: 1px solid var(--g-border);
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 12px;
}

.g-install-cmd {
  font-family: var(--font-mono);
  font-size: 0.95rem;
  background: transparent;
  border: none;
  padding: 10px 16px;
  color: var(--g-text);
  border-radius: 0;
  user-select: all;
}

.g-copy-btn {
  background: transparent;
  border: none;
  border-left: 1px solid var(--g-border);
  color: var(--g-text-dim);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  padding: 10px 14px;
  cursor: pointer;
  transition: color 0.15s, background 0.15s;
}
.g-copy-btn:hover { color: var(--g-text); background: var(--g-border); }
.g-copy-btn--done { color: var(--g-accent); }

.g-hero-sub {
  font-size: 0.85rem;
  color: var(--g-text-dim);
}

/* ── Demo section ────────────────────────────────────────────────────── */
.g-demo-section {
  padding: 0 0 80px;
}

/* ── Generic section ─────────────────────────────────────────────────── */
.g-section {
  padding: 72px 0;
  border-top: 1px solid var(--g-border);
}
.g-section--accent {
  background: var(--g-bg-subtle);
}

.g-section-h {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--g-text-dim);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 28px;
  font-family: var(--font-mono);
  display: flex;
  align-items: center;
  gap: 10px;
}
.g-section-h::before {
  content: '';
  display: inline-block;
  width: 20px;
  height: 1px;
  background: var(--g-accent);
  flex-shrink: 0;
}

.g-section p {
  color: var(--g-text);
  line-height: 1.75;
  margin-bottom: 16px;
}
.g-section p:last-child { margin-bottom: 0; }

/* ── Operations ──────────────────────────────────────────────────────── */
.g-ops {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-top: 1px solid var(--g-border);
}

.g-op {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 28px 28px 28px 0;
  border-right: 1px solid var(--g-border);
}
.g-op:last-child { border-right: none; padding-right: 0; }
.g-op:not(:first-child) { padding-left: 28px; padding-right: 28px; }
.g-op:last-child { padding-right: 0; }

.g-op dt {
  font-family: var(--font-mono);
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--g-text);
  margin-bottom: 10px;
}
.g-op dt a { color: var(--g-text); }
.g-op dt a:hover { color: var(--g-accent-hi); text-decoration: none; }

.g-op dd {
  color: var(--g-text-dim);
  line-height: 1.65;
  font-size: 0.875rem;
  margin-bottom: 12px;
  flex: 1;
}

.g-op-cmd {
  background: var(--g-code-bg);
  border: 1px solid var(--g-border);
  border-radius: 4px;
  padding: 8px 12px;
  overflow-x: auto;
  white-space: nowrap;
  margin: 0;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--g-text-dim);
}
.g-op-cmd code {
  background: transparent;
  border: none;
  padding: 0;
  font-size: inherit;
  color: inherit;
  white-space: nowrap;
}

/* ── Benchmarks ──────────────────────────────────────────────────────── */
.g-bench-row {
  display: flex;
  gap: 48px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.g-bench-stat {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.g-bench-num {
  font-family: var(--font-mono);
  font-size: clamp(2.5rem, 7vw, 4rem);
  font-weight: 700;
  color: var(--g-accent-hi);
  line-height: 1;
  letter-spacing: -0.03em;
}

.g-bench-label {
  font-size: 0.875rem;
  color: var(--g-text-dim);
  line-height: 1.4;
}

.g-bench-note {
  font-size: 0.825rem;
  color: var(--g-text-dim);
  line-height: 1.6;
}

/* ── Code block ──────────────────────────────────────────────────────── */
.g-pre {
  background: var(--g-code-bg);
  border: 1px solid var(--g-border);
  border-radius: 6px;
  padding: 20px 24px;
  overflow-x: auto;
  margin: 24px 0;
  font-family: var(--font-mono);
  font-size: 0.85rem;
  line-height: 1.7;
}
.g-pre code {
  background: transparent;
  border: none;
  padding: 0;
  font-size: inherit;
  color: var(--g-text);
}

.p-dim  { color: var(--g-text-dim); }
.p-str  { color: #98c379; }
.p-expr { color: var(--g-accent-hi); }
.p-label { color: var(--g-text-dim); }
.p-prompt { color: var(--g-text); }

/* ── Note ────────────────────────────────────────────────────────────── */
.g-note {
  font-size: 0.85rem !important;
  color: var(--g-text-dim) !important;
}

/* ── List ────────────────────────────────────────────────────────────── */
.g-list {
  list-style: none;
  padding: 0;
  margin: 16px 0 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.g-list li {
  font-size: 0.9375rem;
  color: var(--g-text);
  padding-left: 16px;
  position: relative;
}
.g-list li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--g-accent);
}

/* ── Footer ──────────────────────────────────────────────────────────── */
.g-footer {
  border-top: 1px solid var(--g-border);
  padding: 28px 0;
}
.g-footer .g-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  font-size: 0.825rem;
  color: var(--g-text-dim);
}
.g-footer a { color: var(--g-text-dim); }
.g-footer a:hover { color: var(--g-text); }
.g-footer-sep { color: var(--g-text-mute); }
.g-footer-copy { color: var(--g-text-mute); }

/* ── Disclaimer ──────────────────────────────────────────────────────── */
.g-disclaimer {
  font-size: 0.8rem !important;
  color: var(--g-text-dim) !important;
  opacity: 0.7;
  border-top: 1px solid var(--g-border);
  padding-top: 16px;
  margin-top: 20px !important;
}

/* ── Responsive ──────────────────────────────────────────────────────── */
@media (max-width: 860px) {
  .g-ops { grid-template-columns: 1fr; }
  .g-op {
    border-right: none;
    border-bottom: 1px solid var(--g-border);
    padding: 24px 0 !important;
  }
  .g-op:last-child { border-bottom: none; }
}

@media (max-width: 600px) {
  .g-bench-row { gap: 28px; }
  .g-nav-links { gap: 16px; }
  .g-hero { padding: 64px 0 48px; }
}
</style>
